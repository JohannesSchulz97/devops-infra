# Server access
SSH_USER=

# BorgBackup (Hetzner Storage Box)
BORG_PASSPHRASE=
BORG_BASE=ssh://<storage-box-id>@<storage-box-id>.your-storagebox.de:23/.

# Cloudflare R2 (off-site backups)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=devops-backup

# PostgreSQL (for R2 backup script)
PG_CONTAINER=crm-stack-db-1
PG_USER=twenty
PG_PASSWORD=
PG_DATABASE=default
PG_SCHEMA=foundry

# Dagster → Twenty CRM integration
# Direct SQL connection for bulk loads
TARGET_POSTGRES_URL=postgresql://twenty:<password>@twenty-db:5432/default
# REST API for incremental sync (generate key in crm.<host-domain> → Settings → API & Webhooks)
TWENTY_API_URL=https://crm.<host-domain>
TWENTY_API_KEY=
