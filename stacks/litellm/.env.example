# LiteLLM proxy master key (must start with sk-) — authenticates admin calls.
# Generate: openssl rand -hex 32 | sed 's/^/sk-/'
LITELLM_MASTER_KEY=

# LiteLLM salt key — encrypts virtual-key API credentials stored in Postgres.
# DO NOT LOSE. Rotating invalidates all stored keys.
# Generate: openssl rand -hex 32
LITELLM_SALT_KEY=

# Postgres
# Generate: openssl rand -hex 24  (avoid base64 — / and + break connection URIs)
POSTGRES_PASSWORD=
LITELLM_DATABASE_URL=postgresql://litellm:<password>@litellm-db:5432/litellm

# Upstream provider keys
FIREWORKS_API_KEY=
GEMINI_API_KEY=

# Google OAuth SSO for the admin UI at https://llm.<host-domain>/ui
# Free up to 5 users since LiteLLM v1.76.0 — no Enterprise license needed at our size.
# Set up a "Web application" OAuth client in Google Cloud Console with redirect URI
# https://llm.<host-domain>/sso/callback (and JS origin https://llm.<host-domain>).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
PROXY_BASE_URL=https://llm.<host-domain>

# PROXY_ADMIN_ID — required. Set to the SSO user_id of the proxy admin.
# Procedure (one-time bootstrap):
#   1. Sign in once at https://llm.<host-domain>/ui to create the user record
#      (you'll land as `internal_user_viewer` per default_internal_user_params).
#   2. Copy your user_id from the UI Users tab and paste it here, then restart.
#   3. PROXY_ADMIN_ID alone does NOT promote an already-created user. Promote
#      explicitly via the API:
#        KEY=$(grep ^LITELLM_MASTER_KEY= .env | cut -d= -f2-)
#        curl -sH "Authorization: Bearer $KEY" -H "Content-Type: application/json" \
#          -X POST http://127.0.0.1:4000/user/update \
#          -d '{"user_id":"<id>","user_role":"proxy_admin"}'
#   PROXY_ADMIN_ID is still required so LiteLLM treats this user as the bootstrap
#   admin (e.g. for license/feature gating and admin-only endpoints).
PROXY_ADMIN_ID=
